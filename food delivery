<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Campus Canteen — Order Board</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=IBM+Plex+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root{
    --chalk-green:#243B32;
    --chalk-green-dk:#182A24;
    --turmeric:#E8A93A;
    --paper:#F2EFE6;
    --paper-dim:#E6E1D2;
    --rust:#B5482F;
    --ink:#1B1F1C;
    --veg:#2F8F4E;
    --nonveg:#B5482F;
    --radius:4px;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background:var(--paper);
    background-image:radial-gradient(circle at 1px 1px, rgba(0,0,0,0.05) 1px, transparent 0);
    background-size:18px 18px;
    color:var(--ink);
    font-family:'Inter',sans-serif;
    min-height:100vh;
  }

  header{
    background:var(--chalk-green);
    color:var(--paper);
    padding:20px 24px 18px;
    border-bottom:6px solid var(--turmeric);
  }
  .header-inner{ max-width:1180px; margin:0 auto; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:14px; }
  .brand-title{ font-family:'Archivo Black',sans-serif; font-size:clamp(22px,4vw,32px); margin:0; }
  .brand-sub{ font-size:12px; color:var(--paper-dim); opacity:0.75; margin-top:4px; }

  nav.tabs{ display:flex; gap:6px; }
  .tab-link{
    font-family:'IBM Plex Mono',monospace;
    font-size:11px; letter-spacing:0.06em; text-transform:uppercase;
    background:transparent; border:1.5px solid var(--paper-dim); color:var(--paper-dim);
    padding:7px 12px; border-radius:20px; cursor:pointer;
  }
  .tab-link.active{ background:var(--turmeric); color:var(--ink); border-color:var(--turmeric); }

  main{ max-width:1180px; margin:0 auto; padding:28px 24px 100px; }
  .view{ display:none; }
  .view.active{ display:block; }

  /* ---- MENU VIEW ---- */
  .menu-layout{ display:grid; grid-template-columns:1fr 340px; gap:26px; align-items:start; }
  @media (max-width:860px){ .menu-layout{ grid-template-columns:1fr; } }

  .menu-section-title{ font-family:'Archivo Black',sans-serif; font-size:20px; margin:26px 0 4px; }
  .menu-section-title:first-child{ margin-top:0; }
  .menu-divider{ border:none; border-top:2px dashed #cfc9b8; margin:8px 0 16px; }

  .menu-grid{ display:grid; grid-template-columns:repeat(auto-fill,minmax(230px,1fr)); gap:12px; }
  .item-card{ background:#fff; border:1px solid #e4dfd0; border-radius:var(--radius); padding:12px 14px; display:flex; flex-direction:column; gap:6px; }
  .item-top{ display:flex; justify-content:space-between; gap:8px; }
  .veg-dot{ width:13px;height:13px; border:2px solid var(--veg); border-radius:3px; display:flex; align-items:center; justify-content:center; flex-shrink:0; margin-top:2px; }
  .veg-dot.nonveg{ border-color:var(--nonveg); }
  .veg-dot::after{ content:''; width:5px;height:5px; border-radius:50%; background:var(--veg); }
  .veg-dot.nonveg::after{ background:var(--nonveg); }
  .item-name{ font-weight:700; font-size:14.5px; }
  .item-desc{ font-size:12px; color:#8a8578; min-height:30px; }
  .item-bottom{ display:flex; justify-content:space-between; align-items:center; margin-top:4px; }
  .item-price{ font-family:'IBM Plex Mono',monospace; font-weight:600; font-size:13.5px; }
  .add-btn, .btn{ background:var(--chalk-green); color:var(--paper); border:none; font-family:'IBM Plex Mono',monospace; font-size:12px; padding:7px 12px; border-radius:3px; cursor:pointer; }
  .add-btn:hover, .btn:hover{ background:var(--chalk-green-dk); }
  .btn:disabled{ background:#d9d2c0; color:#a39d8b; cursor:not-allowed; }
  .qty-control{ display:flex; align-items:center; gap:8px; background:var(--chalk-green); border-radius:3px; padding:4px 6px; }
  .qty-control button{ background:none; border:none; color:var(--paper); font-size:15px; cursor:pointer; width:18px; }
  .qty-control span{ color:var(--paper); font-family:'IBM Plex Mono',monospace; font-size:13px; }

  /* ---- SLIP / CART ---- */
  .slip{ background:#fff; border:1px solid #e4dfd0; box-shadow:0 10px 30px rgba(0,0,0,0.15); padding:18px 20px; font-family:'IBM Plex Mono',monospace; position:sticky; top:20px; }
  .slip-title{ font-family:'Archivo Black',sans-serif; font-size:17px; text-align:center; }
  .slip-sub{ text-align:center; font-size:10px; letter-spacing:0.12em; text-transform:uppercase; color:#8a8578; margin-bottom:12px; }
  .slip-divider{ border:none; border-top:1px dashed #cfc9b8; margin:10px 0; }
  .cart-empty{ text-align:center; font-size:12.5px; color:#a39d8b; padding:20px 4px; }
  .cart-line{ display:flex; justify-content:space-between; gap:8px; font-size:12.5px; padding:5px 0; }
  .cart-line .remove{ background:none; border:none; color:var(--rust); cursor:pointer; font-family:inherit; }
  .slip-total-row{ display:flex; justify-content:space-between; font-size:14px; font-weight:700; padding-top:6px; }
  .place-order-btn{ width:100%; background:var(--rust); color:#fff; border:none; padding:11px; font-family:'Archivo Black',sans-serif; font-size:13px; border-radius:3px; cursor:pointer; margin-top:12px; }
  .place-order-btn:hover:not(:disabled){ background:#963a24; }
  .place-order-btn:disabled{ background:#d9d2c0; color:#a39d8b; cursor:not-allowed; }

  /* ---- TRACK ORDER VIEW ---- */
  .track-wrap{ max-width:460px; margin:0 auto; }
  .token-display{ text-align:center; padding:20px 0 10px; }
  .token-display .num{ font-family:'Archivo Black',sans-serif; font-size:46px; color:var(--rust); }
  .steps{ display:flex; justify-content:space-between; margin:18px 0 20px; }
  .step{ text-align:center; flex:1; }
  .step .dot{ width:14px;height:14px;border-radius:50%; margin:0 auto 6px; background:#d9d2c0; }
  .step.done .dot{ background:var(--rust); }
  .step .label{ font-size:9.5px; font-family:'IBM Plex Mono',monospace; text-transform:uppercase; color:#8a8578; }
  .step.done .label{ color:var(--ink); }
  .no-order{ text-align:center; color:#8a8578; padding:60px 20px; font-size:13px; }

  /* ---- ADMIN VIEW ---- */
  table.admin-table{ width:100%; border-collapse:collapse; margin-top:10px; background:#fff; }
  .admin-table th, .admin-table td{ text-align:left; padding:10px 12px; border-bottom:1px solid #e4dfd0; font-size:13px; }
  .admin-table th{ font-family:'IBM Plex Mono',monospace; font-size:10.5px; text-transform:uppercase; letter-spacing:0.05em; color:#8a8578; }
  .status-badge{ display:inline-block; padding:3px 10px; border-radius:12px; font-size:10.5px; text-transform:uppercase; font-family:'IBM Plex Mono',monospace; }
  .status-placed{ background:#e6e1d2; color:#5a5647; }
  .status-preparing{ background:#fbe3b8; color:#8a5a15; }
  .status-ready{ background:#d5efd9; color:#206a35; }
  .status-picked_up{ background:#d9e3f0; color:#2c4d7a; }
  .empty-row{ text-align:center; color:#a39d8b; padding:24px; font-size:13px; }
  .sync-note{ font-size:11.5px; color:#8a8578; margin-top:14px; font-family:'IBM Plex Mono',monospace; }

  .toast{ position:fixed; bottom:22px; left:50%; transform:translateX(-50%) translateY(20px); background:var(--chalk-green-dk); color:var(--paper); padding:10px 18px; border-radius:4px; font-family:'IBM Plex Mono',monospace; font-size:12.5px; opacity:0; pointer-events:none; transition:all .25s ease; z-index:50; border:1px solid rgba(232,169,58,0.4); }
  .toast.show{ opacity:1; transform:translateX(-50%) translateY(0); }
</style>
</head>
<body>

<header>
  <div class="header-inner">
    <div>
      <h1 class="brand-title">CAMPUS CANTEEN</h1>
      <p class="brand-sub">Order ahead. Skip the queue.</p>
    </div>
    <nav class="tabs">
      <button class="tab-link active" data-view="menu">Menu</button>
      <button class="tab-link" data-view="track">Track Order</button>
      <button class="tab-link" data-view="admin">Admin Dashboard</button>
    </nav>
  </div>
</header>

<main>

  <!-- MENU VIEW -->
  <section class="view active" id="view-menu">
    <div class="menu-layout">
      <div id="menuContainer"></div>
      <div class="slip">
        <div class="slip-title">TOKEN SLIP</div>
        <div class="slip-sub">Your order</div>
        <hr class="slip-divider">
        <div id="slipBody"></div>
      </div>
    </div>
  </section>

  <!-- TRACK ORDER VIEW -->
  <section class="view" id="view-track">
    <div class="track-wrap" id="trackWrap"></div>
  </section>

  <!-- ADMIN VIEW -->
  <section class="view" id="view-admin">
    <h2 class="menu-section-title">Live Order Queue</h2>
    <hr class="menu-divider">
    <table class="admin-table">
      <thead>
        <tr><th>Token</th><th>Items</th><th>Total</th><th>Status</th><th>Placed</th><th></th></tr>
      </thead>
      <tbody id="adminBody"></tbody>
    </table>
    <p class="sync-note">Open this page in a second tab to place an order there and watch it appear here live — status changes here push back to the customer's tracking screen in real time.</p>
  </section>

</main>

<div class="toast" id="toast"></div>

<script>
/* ================= DATA ================= */
const MENU = {
  "Tiffin": [
    {id:'t1', name:'Masala Dosa', desc:'Crisp rice crepe, potato masala, chutney, sambar', price:45, veg:true},
    {id:'t2', name:'Idli Sambar (4pc)', desc:'Steamed rice cakes with sambar and coconut chutney', price:35, veg:true},
    {id:'t3', name:'Aloo Paratha', desc:'Stuffed flatbread, curd, pickle', price:40, veg:true},
  ],
  "Meals": [
    {id:'m1', name:'Veg Thali', desc:'Rice, dal, sabzi, roti (2), salad, papad', price:70, veg:true},
    {id:'m2', name:'Chicken Curry Meal', desc:'Rice, chicken curry, salad, papad', price:95, veg:false},
    {id:'m3', name:'Rajma Chawal', desc:'Kidney bean curry over steamed rice', price:55, veg:true},
  ],
  "Snacks": [
    {id:'s1', name:'Veg Puff', desc:'Flaky pastry, spiced vegetable filling', price:20, veg:true},
    {id:'s2', name:'Chicken Roll', desc:'Paratha wrap, chicken filling, mint chutney', price:50, veg:false},
    {id:'s3', name:'Samosa (2pc)', desc:'Crisp pastry, spiced potato filling', price:20, veg:true},
  ],
  "Beverages": [
    {id:'b1', name:'Filter Coffee', desc:'South Indian style, served hot', price:15, veg:true},
    {id:'b2', name:'Masala Chai', desc:'Spiced milk tea', price:12, veg:true},
    {id:'b3', name:'Cold Coffee', desc:'Blended with ice cream', price:35, veg:true},
  ],
};
const STEPS = ['placed','preparing','ready','picked_up'];
const STEP_LABEL = { placed:'Placed', preparing:'Preparing', ready:'Ready', picked_up:'Picked up' };

let cart = {};              // itemId -> qty
let orders = {};            // orderId -> order object (shared store, synced via BroadcastChannel)
let currentOrderId = null;  // the order this tab is tracking
let tokenCounter = 118;

/* Cross-tab sync — stands in for the Socket.io real-time layer */
const channel = ('BroadcastChannel' in window) ? new BroadcastChannel('campus-canteen') : null;
if (channel) {
  channel.onmessage = (e) => {
    const msg = e.data;
    if (msg.type === 'new_order') {
      orders[msg.order.id] = msg.order;
      renderAdmin();
    }
    if (msg.type === 'status_update') {
      if (orders[msg.orderId]) orders[msg.orderId].status = msg.status;
      renderAdmin();
      if (currentOrderId === msg.orderId) renderTrack();
    }
  };
}

/* ================= TABS ================= */
document.querySelectorAll('.tab-link').forEach(btn=>{
  btn.addEventListener('click', ()=> switchView(btn.dataset.view));
});
function switchView(name){
  document.querySelectorAll('.tab-link').forEach(b=> b.classList.toggle('active', b.dataset.view===name));
  document.querySelectorAll('.view').forEach(v=> v.classList.remove('active'));
  document.getElementById('view-'+name).classList.add('active');
  if(name==='track') renderTrack();
  if(name==='admin') renderAdmin();
}

/* ================= MENU ================= */
function allItemsFlat(){ return Object.values(MENU).flat(); }

function renderMenu(){
  const el = document.getElementById('menuContainer');
  el.innerHTML = Object.entries(MENU).map(([sec, items])=>`
    <h2 class="menu-section-title">${sec}</h2>
    <hr class="menu-divider">
    <div class="menu-grid">
      ${items.map(itemCardHTML).join('')}
    </div>
  `).join('');
  el.querySelectorAll('.item-card').forEach(card=>{
    const id = card.dataset.id;
    card.querySelectorAll('button').forEach(btn=>{
      btn.addEventListener('click', ()=>{
        const action = btn.dataset.action;
        if(action==='add'||action==='inc') cart[id]=(cart[id]||0)+1;
        if(action==='dec'){ cart[id]=(cart[id]||0)-1; if(cart[id]<=0) delete cart[id]; }
        renderMenu(); renderSlip();
      });
    });
  });
}
function itemCardHTML(item){
  const qty = cart[item.id]||0;
  return `
    <div class="item-card" data-id="${item.id}">
      <div class="item-top">
        <span class="item-name">${item.name}</span>
        <span class="veg-dot ${item.veg?'':'nonveg'}"></span>
      </div>
      <div class="item-desc">${item.desc}</div>
      <div class="item-bottom">
        <span class="item-price">₹${item.price}</span>
        ${qty===0
          ? `<button class="add-btn" data-action="add">ADD</button>`
          : `<div class="qty-control"><button data-action="dec">−</button><span>${qty}</span><button data-action="inc">+</button></div>`}
      </div>
    </div>`;
}

/* ================= CART / SLIP ================= */
function renderSlip(){
  const body = document.getElementById('slipBody');
  const flat = allItemsFlat();
  const entries = Object.entries(cart);

  if(entries.length===0){
    body.innerHTML = `<div class="cart-empty">Your slip is empty.<br>Tap ADD on any item to begin.</div>
      <button class="place-order-btn" disabled>PLACE ORDER</button>`;
    return;
  }
  let total = 0;
  const lines = entries.map(([id,qty])=>{
    const item = flat.find(i=>i.id===id);
    const lineTotal = item.price*qty;
    total += lineTotal;
    return `<div class="cart-line">
      <span style="flex:1">${item.name}</span><span style="color:#8a8578">x${qty}</span>
      <span>₹${lineTotal}</span>
      <button class="remove" data-id="${id}">✕</button>
    </div>`;
  }).join('');

  body.innerHTML = `${lines}<hr class="slip-divider">
    <div class="slip-total-row"><span>TOTAL</span><span>₹${total}</span></div>
    <button class="place-order-btn" id="placeOrderBtn">PLACE ORDER</button>`;

  body.querySelectorAll('.remove').forEach(btn=>{
    btn.addEventListener('click', ()=>{ delete cart[btn.dataset.id]; renderMenu(); renderSlip(); });
  });
  document.getElementById('placeOrderBtn').addEventListener('click', placeOrder);
}

function placeOrder(){
  const flat = allItemsFlat();
  const items = Object.entries(cart).map(([id,qty])=>{
    const item = flat.find(i=>i.id===id);
    return { id, name:item.name, price:item.price, qty };
  });
  const total = items.reduce((s,i)=> s + i.price*i.qty, 0);
  tokenCounter += 1;

  const order = {
    id: 'ord_' + Date.now(),
    token: tokenCounter,
    items,
    total,
    status: 'placed',
    createdAt: new Date().toISOString(),
  };

  orders[order.id] = order;
  currentOrderId = order.id;
  cart = {};

  if (channel) channel.postMessage({ type:'new_order', order });
  renderAdmin();

  showToast(`Order placed — token #${order.token}`);
  switchView('track');
}

/* ================= TRACK ORDER ================= */
function renderTrack(){
  const wrap = document.getElementById('trackWrap');
  const order = orders[currentOrderId];
  if(!order){
    wrap.innerHTML = `<div class="no-order">No active order yet.<br>Place one from the Menu tab.</div>`;
    return;
  }
  const currentIndex = STEPS.indexOf(order.status);
  wrap.innerHTML = `
    <div class="slip">
      <div class="token-display">
        <div style="font-size:11px;color:#8a8578;letter-spacing:0.1em;">YOUR TOKEN</div>
        <div class="num">#${order.token}</div>
      </div>
      <div class="steps">
        ${STEPS.map((s,i)=>`
          <div class="step ${i<=currentIndex?'done':''}">
            <div class="dot"></div>
            <div class="label">${STEP_LABEL[s]}</div>
          </div>`).join('')}
      </div>
      <hr class="slip-divider">
      ${order.items.map(it=>`
        <div class="cart-line"><span>${it.name} × ${it.qty}</span><span>₹${it.price*it.qty}</span></div>
      `).join('')}
      <div class="slip-total-row"><span>TOTAL</span><span>₹${order.total}</span></div>
      <p style="text-align:center;font-size:11.5px;color:#8a8578;margin-top:14px;">
        This screen updates automatically when the canteen updates your order.
      </p>
    </div>`;
}

/* ================= ADMIN ================= */
function renderAdmin(){
  const body = document.getElementById('adminBody');
  const list = Object.values(orders)
    .filter(o=> o.status!=='picked_up')
    .sort((a,b)=> new Date(a.createdAt) - new Date(b.createdAt));

  if(list.length===0){
    body.innerHTML = `<tr><td colspan="6" class="empty-row">No active orders.</td></tr>`;
    return;
  }
  const nextStatus = { placed:'preparing', preparing:'ready', ready:'picked_up' };
  const nextLabel = { placed:'Start preparing', preparing:'Mark ready', ready:'Mark picked up' };

  body.innerHTML = list.map(o=>`
    <tr>
      <td>#${o.token}</td>
      <td>${o.items.map(i=>`${i.name} ×${i.qty}`).join(', ')}</td>
      <td>₹${o.total}</td>
      <td><span class="status-badge status-${o.status}">${o.status.replace('_',' ')}</span></td>
      <td>${new Date(o.createdAt).toLocaleTimeString()}</td>
      <td>${nextStatus[o.status] ? `<button class="btn" data-id="${o.id}">${nextLabel[o.status]}</button>` : ''}</td>
    </tr>
  `).join('');

  body.querySelectorAll('button[data-id]').forEach(btn=>{
    btn.addEventListener('click', ()=>{
      const order = orders[btn.dataset.id];
      const ns = nextStatus[order.status];
      if(!ns) return;
      order.status = ns;
      if (channel) channel.postMessage({ type:'status_update', orderId: order.id, status: ns });
      renderAdmin();
      if(currentOrderId === order.id) renderTrack();
      showToast(`Token #${order.token} → ${ns.replace('_',' ')}`);
    });
  });
}

/* ================= TOAST ================= */
let toastTimer;
function showToast(msg){
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(()=> t.classList.remove('show'), 2400);
}

/* ================= INIT ================= */
renderMenu();
renderSlip();
renderAdmin();
</script>

</body>
</html>